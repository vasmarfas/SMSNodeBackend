# ─────────────────────────────────────────────────────────────────────────────
# Telegram Bot
# ─────────────────────────────────────────────────────────────────────────────
BOT_TOKEN=1234567890:YOUR_BOT_TOKEN_HERE
ADMIN_ID=123456789
RSCHS_CHAT_ID=123456789

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL — заполни при разворачивании на новом стенде
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sms_gateway
POSTGRES_USER=sms_user
POSTGRES_PASSWORD=change_me_strong_password
# Порт для подключения к БД извне (только для Docker)
DB_PORT_EXTERNAL=127.0.0.1:5432

# ─────────────────────────────────────────────────────────────────────────────
# JWT — ОБЯЗАТЕЛЬНО смени секретный ключ на продакшне!
# Генерация: python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────────────────────────────────────
API_SECRET_KEY=REPLACE_THIS_WITH_LONG_RANDOM_SECRET_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─────────────────────────────────────────────────────────────────────────────
# FastAPI server
# ─────────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8007

# ─────────────────────────────────────────────────────────────────────────────
# Режим регистрации (можно переопределить в админке: GET/PATCH /api/v1/admin/settings/registration-mode)
# open — кто угодно может зарегистрироваться (бот /start или API /auth/register)
# closed — только создание учётки админом или по приглашению
# semi_open — можно подать заявку, учётку создаёт админ после одобрения
# ─────────────────────────────────────────────────────────────────────────────
REGISTRATION_MODE=open

# ─────────────────────────────────────────────────────────────────────────────
# Telegram Bot — дополнительные настройки
# ─────────────────────────────────────────────────────────────────────────────
MAX_CHANNELS=8
MINI_APP_URL=https://your-mini-app-domain.com

# Глобальный интервал отправки SMS для одного канала (секунды)
# Используется очередью sms_queue для предотвращения блокировки SIM-карт
MIN_INTERVAL_PER_CHANNEL_SEC=5.0

# ─────────────────────────────────────────────────────────────────────────────
# Опционально: Использование готового Docker-образа (GHCR)
# ─────────────────────────────────────────────────────────────────────────────
# Раскомментируйте, если не хотите собирать образ локально
# DOCKER_IMAGE=ghcr.io/vasmarfas/smsnodebackend:latest

# ─────────────────────────────────────────────────────────────────────────────
# Демо-режим (Read-Only)
# ─────────────────────────────────────────────────────────────────────────────
IS_DEMO=False

# ─────────────────────────────────────────────────────────────────────────────
# Legacy (GoIP из конфига — теперь шлюзы добавляются через /gateways в боте)
# Оставлены для совместимости, не обязательны
# ─────────────────────────────────────────────────────────────────────────────
GOIP_IP=
GOIP_LOGIN=
GOIP_PASSWORD=
